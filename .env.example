# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# Database
DATABASE_PATH=./olt-api.db

# Cache
CACHE_ENABLED=true
CACHE_TTL=60s

# Scraper
SCRAPER_TIMEOUT=30s
SCRAPER_MAX_WORKERS=200

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Auth
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_TTL=12h
AUTH_INITIAL_USERNAME=admin
AUTH_INITIAL_PASSWORD=admin
